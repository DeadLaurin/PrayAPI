# --- Server ---
PORT=3000
HOST=0.0.0.0

# production | development
NODE_ENV=development

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Behind nginx, Caddy, Cloudflare, etc. — set so req.ip / X-Forwarded-* work
TRUST_PROXY=false

# CORS: omit = allow any origin. For production set your front-end origin(s):
# CORS_ORIGIN=https://app.example.com
# CORS_ORIGIN=https://a.com,https://b.com
